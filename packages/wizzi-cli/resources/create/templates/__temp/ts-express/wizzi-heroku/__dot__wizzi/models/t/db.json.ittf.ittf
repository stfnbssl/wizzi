${'$'}group 
   useMongoDb true
   { mongoDb
       host "mongodb+srv"
       user "yanez"
       password "${'$'}{stfnbssl_env.mongoDbPsw}"
       dbPath "@cluster0.idlk7.mongodb.net"
       dbName "wizzi"
       { options
           useNewUrlParser true
           useUnifiedTopology true
   useSequelize true
   { sequelize
       databaseUrl "${'$'}{stfnbssl_env.sequelizeDbUrl}"