${'$'}group 
   useWizzi true
   { wizzi
       isDev true
       [ plugins
           "wizzi-core" 
           "wizzi-js" 
           "wizzi-web" 
       { globalContext
           wzConfigIsDevelopment true
       useRunner false
   useIttfStatic true
   { ittfStatic
   useWizziViewEngine true
   { wizziViewEngine