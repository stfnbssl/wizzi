v08/artifacts/statements-writer(control)

	$append imports
            
	v08/artifacts/statement( xif
        _ ctx.w('if (' + name + ') {')
        _ mainWriter.genItems
            @ model.statements
            @ ctx
            {
                @ indent true
            a_cb()
                _ ctx.w('}')
                r_cb()

	v08/artifacts/statement( xelse
        _ ctx.w('else {')
        _ mainWriter.genItems
            @ model.statements
            @ ctx
            {
                @ indent true
            a_cb()
                _ ctx.w('}')
                r_cb()

