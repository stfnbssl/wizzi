	v08/artifacts/statement( label
        var save = ctx.forceIndent(1)
        _ ctx.w(name + ':')
        _ mainWriter.genItems
            @ model.statements
            @ ctx
            {
                @ indent true
            a_cb()
                _ ctx.forceIndent(save)
                r_cb()                