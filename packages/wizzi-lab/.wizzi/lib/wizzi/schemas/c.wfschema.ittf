wfschema c

    e statement
		# A statement line node with unlimited depth.
		# Is the schema base node.
		# In itself works as a comment line.
		tag //
		r statement/s

	e codeline : statement

    e c : statement
		is-root
        any codeline/statements

	e param

    e function : statement
        a rtype
            # return type
        r param/s
        any codeline/statements
	
    e return : statement

    $$ $include c/...