wfschema wfpackage

	# A Wizzi Schema modeling a Wizzi Package

	export-to json
	
	$include common/comments
	
	e wfpackage : commentable
		# The root tag of the wfpackage schema.
		is-root

		$include wfpackage/attributes_relations
		$include wfpackage/methods
		r fsInfo
			one-to-one
		r folder/s
		r document/s

    $include wfpackage/elements

	$include fs/index