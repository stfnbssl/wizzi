                                            is-fragment
                                            ittf <div class="L1"><span class="pp-ln">   1 </span><span class="pp-pln"></span><span class="pp-kwd">└group</span></div><div class="L2"><span class="pp-ln">   2 </span><span class="pp-pln">    </span><span class="pp-tag">e</span><span class="pp-pln"> transformer</span></div><div class="L3"><span class="pp-ln">   3 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> A model transformer.</span></div><div class="L4"><span class="pp-ln">   4 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> The ittf node value is the transformer name {wizzischema}/{transformer}</span></div><div class="L5"><span class="pp-ln">   5 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> to be found in {wizziPackage}/artifacts/{wizzischema}/{transformer}/trans/main.js</span></div><div class="L6"><span class="pp-ln">   6 </span><span class="pp-pln">        </span><span class="pp-mix frag-to-link-a">a_tag(</span><span class="pp-arg"> dumpFile</span><span class="pp-pln">,</span><span class="pp-arg">  dump-file </span><span class="pp-mix">)</span></div><div class="L7"><span class="pp-ln">   7 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> A filepath where the transformed model must be dumped for test.</span></div><div class="L8"><span class="pp-ln">   8 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> When declared the transformed model is JSON.stringified and written</span></div><div class="L9"><span class="pp-ln">   9 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> to the "dumpFile" filepath.</span></div><div class="L0"><span class="pp-ln">  10 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> comment/s</span></div><div class="L1"><span class="pp-ln">  11 </span><span class="pp-pln">    </span><span class="pp-tag">e</span><span class="pp-pln"> artifact</span></div><div class="L2"><span class="pp-ln">  12 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> Describe an artifact, or a group of artifacts, to be generated.</span></div><div class="L3"><span class="pp-ln">  13 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> It is a child element of a "line" element.</span></div><div class="L4"><span class="pp-ln">  14 </span><span class="pp-pln">        </span><span class="pp-tag">#</span></div><div class="L5"><span class="pp-ln">  15 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> Each artifact item can be one of:</span></div><div class="L6"><span class="pp-ln">  16 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> . A Wizzi model instance, acting as a template, which WizziSchema targets a code language technology.</span></div><div class="L7"><span class="pp-ln">  17 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> . A swig template.</span></div><div class="L8"><span class="pp-ln">  18 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> . A code write generation that takes in input a context of one or more WizziModels.</span></div><div class="L9"><span class="pp-ln">  19 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> . A final artifact to be copied to a destination folder without transformations.</span></div><div class="L0"><span class="pp-ln">  20 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> . A reference to another WfJob, to be executed before the current WfJob where the artifact is declared.</span></div><div class="L1"><span class="pp-ln">  21 </span><span class="pp-pln">        </span><span class="pp-tag">#</span></div><div class="L2"><span class="pp-ln">  22 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> Context value objects for template transformations are declared in the "model" element, child of the "wfjob" root element</span></div><div class="L3"><span class="pp-ln">  23 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> and may be referenced in the elements "modelRef", children of the "artifact" element.</span></div><div class="L4"><span class="pp-ln">  24 </span><span class="pp-pln">        </span><span class="pp-tag">#</span></div><div class="L5"><span class="pp-ln">  25 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> The "src" attribute can be a glob pattern.</span></div><div class="L6"><span class="pp-ln">  26 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> The "src" or "destPath" attributes of an "artifact" element may contain tokens enclosed in graph parens.</span></div><div class="L7"><span class="pp-ln">  27 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> When one of the "modelRef@" is a collection model, the artifact generation is repeated</span></div><div class="L8"><span class="pp-ln">  28 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> for each item of the collection and the "src" or "destPath" attributes become the template of the destination path.</span></div><div class="L9"><span class="pp-ln">  29 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> See the "pathTemplateValues" child elements of the "modelRef" for the values that will replace the tokens.</span></div><div class="L0"><span class="pp-ln">  30 </span><span class="pp-pln">        </span><span class="pp-tag">#</span></div><div class="L1"><span class="pp-ln">  31 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> Example</span></div><div class="L2"><span class="pp-ln">  32 </span><span class="pp-pln">        </span><span class="pp-tag">#</span></div><div class="L3"><span class="pp-ln">  33 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> artifact</span></div><div class="L4"><span class="pp-ln">  34 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> dest-path app/db/{table}Datalayer.js.ittf</span></div><div class="L5"><span class="pp-ln">  35 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> ...</span></div><div class="L6"><span class="pp-ln">  36 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> model-ref rdbms</span></div><div class="L7"><span class="pp-ln">  37 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> model-coll tables</span></div><div class="L8"><span class="pp-ln">  38 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> item-name table</span></div><div class="L9"><span class="pp-ln">  39 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> path-template-value</span></div><div class="L0"><span class="pp-ln">  40 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> attribute tableName</span></div><div class="L1"><span class="pp-ln">  41 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> token table</span></div><div class="L2"><span class="pp-ln">  42 </span><span class="pp-pln">        </span><span class="pp-tag">#</span></div><div class="L3"><span class="pp-ln">  43 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> model rdbms</span></div><div class="L4"><span class="pp-ln">  44 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> ...</span></div><div class="L5"><span class="pp-ln">  45 </span><span class="pp-pln">        </span><span class="pp-tag">#</span></div><div class="L6"><span class="pp-ln">  46 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> the Wizzi model instance after loading rdbms: {</span></div><div class="L7"><span class="pp-ln">  47 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> ....</span></div><div class="L8"><span class="pp-ln">  48 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> tables: [{</span></div><div class="L9"><span class="pp-ln">  49 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> tableName: 'user',</span></div><div class="L0"><span class="pp-ln">  50 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> ...</span></div><div class="L1"><span class="pp-ln">  51 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> },{</span></div><div class="L2"><span class="pp-ln">  52 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> ...</span></div><div class="L3"><span class="pp-ln">  53 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> }]</span></div><div class="L4"><span class="pp-ln">  54 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> }</span></div><div class="L5"><span class="pp-ln">  55 </span><span class="pp-pln">        </span><span class="pp-tag">#</span></div><div class="L6"><span class="pp-ln">  56 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> will produce an artifact of path .../app/db/userDatalayer.js, and as many as the items in the tables collection.</span></div><div class="L7"><span class="pp-ln">  57 </span><span class="pp-pln">        </span><span class="pp-tag">#</span></div><div class="L8"><span class="pp-ln">  58 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> src</span></div><div class="L9"><span class="pp-ln">  59 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The path to the primary ittf source document of the artifact, in case of a wizzi model, or</span></div><div class="L0"><span class="pp-ln">  60 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> to a native source in case of a POJO.</span></div><div class="L1"><span class="pp-ln">  61 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Can be a glob pattern referencing many ittf source documents of artifacts of the same kind.</span></div><div class="L2"><span class="pp-ln">  62 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> FIXME explain why this:</span></div><div class="L3"><span class="pp-ln">  63 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Or it may contain the literal 'context' if the artifact generator require a context object only</span></div><div class="L4"><span class="pp-ln">  64 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> and not a primary model.</span></div><div class="L5"><span class="pp-ln">  65 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> If relative, the base path is the cwdFolder of the parent line.</span></div><div class="L6"><span class="pp-ln">  66 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> If the artifact is a code write artifact the 'src' attribute must be omitted.</span></div><div class="L7"><span class="pp-ln">  67 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> ignore</span></div><div class="L8"><span class="pp-ln">  68 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> File returned by the src pattern that must be ignored.</span></div><div class="L9"><span class="pp-ln">  69 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Can be a glob pattern.</span></div><div class="L0"><span class="pp-ln">  70 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> schema</span></div><div class="L1"><span class="pp-ln">  71 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> When the artifact source is a schemed ittf document, is the schema that will load and</span></div><div class="L2"><span class="pp-ln">  72 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> validate the wizzi model instance.</span></div><div class="L3"><span class="pp-ln">  73 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> May be null (absent) if the artifact is a final artifact or the artifact source is a POJO;</span></div><div class="L4"><span class="pp-ln">  74 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> in this case the 'format' attribute must be declared.</span></div><div class="L5"><span class="pp-ln">  75 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> format</span></div><div class="L6"><span class="pp-ln">  76 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> When the artifact source is a POJO model is the native format of the source file.</span></div><div class="L7"><span class="pp-ln">  77 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Is alternative to the attribute 'schema'.</span></div><div class="L8"><span class="pp-ln">  78 </span><span class="pp-pln">            </span><span class="pp-tag">restrict</span></div><div class="L9"><span class="pp-ln">  79 </span><span class="pp-pln">                </span><span class="pp-tag">enum</span><span class="pp-pln"> json</span></div><div class="L0"><span class="pp-ln">  80 </span><span class="pp-pln">                    </span><span class="pp-tag">#</span><span class="pp-pln"> Native JSON file.</span></div><div class="L1"><span class="pp-ln">  81 </span><span class="pp-pln">                </span><span class="pp-tag">enum</span><span class="pp-pln"> xml</span></div><div class="L2"><span class="pp-ln">  82 </span><span class="pp-pln">                    </span><span class="pp-tag">#</span><span class="pp-pln"> Native Xml file.</span></div><div class="L3"><span class="pp-ln">  83 </span><span class="pp-pln">                </span><span class="pp-tag">enum</span><span class="pp-pln"> js</span></div><div class="L4"><span class="pp-ln">  84 </span><span class="pp-pln">                    </span><span class="pp-tag">#</span><span class="pp-pln"> Native javascript module file that may export object properties or</span></div><div class="L5"><span class="pp-ln">  85 </span><span class="pp-pln">                    </span><span class="pp-tag">#</span><span class="pp-pln"> a function named 'toModel'.</span></div><div class="L6"><span class="pp-ln">  86 </span><span class="pp-pln">        </span><span class="pp-mix frag-to-link-a">a_flag(</span><span class="pp-arg"> isCompile</span><span class="pp-pln">,</span><span class="pp-arg">  is-compile </span><span class="pp-mix">)</span></div><div class="L7"><span class="pp-ln">  87 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Indicator that the mTree buildup script must be 'compiled' for javascript</span></div><div class="L8"><span class="pp-ln">  88 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> and loaded with a 'require-from-string' function instead of</span></div><div class="L9"><span class="pp-ln">  89 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> being submitted to js-wizzi.</span></div><div class="L0"><span class="pp-ln">  90 </span><span class="pp-pln">        </span><span class="pp-mix frag-to-link-a">a_flag(</span><span class="pp-arg"> isWfJob</span><span class="pp-pln">,</span><span class="pp-arg">  is-wf-job </span><span class="pp-mix">)</span></div><div class="L1"><span class="pp-ln">  91 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Indicator that the artifact source is a wizzi factory job, alias a wizzi model of schema 'wfjob'.</span></div><div class="L2"><span class="pp-ln">  92 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The job will be executed before any other artifact production of the current wfjob.</span></div><div class="L3"><span class="pp-ln">  93 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> This could be autodected from the schema, but autodetection would forbid other uses or transformations</span></div><div class="L4"><span class="pp-ln">  94 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> of a "wfjob" model, so the indicator is required.</span></div><div class="L5"><span class="pp-ln">  95 </span><span class="pp-pln">        </span><span class="pp-mix frag-to-link-a">a_flag(</span><span class="pp-arg"> isWfModelType</span><span class="pp-pln">,</span><span class="pp-arg">  is-wf-model-type </span><span class="pp-mix">)</span></div><div class="L6"><span class="pp-ln">  96 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Indicator that the artifact source is a wizzi schema, alias a wizzi model of schema 'wfschema'</span></div><div class="L7"><span class="pp-ln">  97 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> and that the generation of the artifacts for the wizzi model described by the wfschema is requested.</span></div><div class="L8"><span class="pp-ln">  98 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> This could be autodected from the schema, but autodetection would forbid other uses or transformations</span></div><div class="L9"><span class="pp-ln">  99 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> of a "wfschema" model, so the indicator is required.</span></div><div class="L0"><span class="pp-ln"> 100 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> generator</span></div><div class="L1"><span class="pp-ln"> 101 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> When the artifact source is a wizzi model instance or a POJO, acting as a context, is the name of</span></div><div class="L2"><span class="pp-ln"> 102 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> the artifact generator that will transform the context into a software artifact.</span></div><div class="L3"><span class="pp-ln"> 103 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> When the artifact is a code write generation or a final artifact must be omitted.</span></div><div class="L4"><span class="pp-ln"> 104 </span><span class="pp-pln">        </span><span class="pp-mix frag-to-link-a">a_tag(</span><span class="pp-arg"> destPath</span><span class="pp-pln">,</span><span class="pp-arg">  dest-path </span><span class="pp-mix">)</span></div><div class="L5"><span class="pp-ln"> 105 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The artifact source file path, 'src', is the default relative destination path</span></div><div class="L6"><span class="pp-ln"> 106 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> of the generated artifact. When set, this attribute overrides the default.</span></div><div class="L7"><span class="pp-ln"> 107 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> It can be an absolute or relative path.</span></div><div class="L8"><span class="pp-ln"> 108 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> If the artifact is a code write generation the 'destPath' attribute is required.</span></div><div class="L9"><span class="pp-ln"> 109 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> extension</span></div><div class="L0"><span class="pp-ln"> 110 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The document path extension of the generated artifact. Optional. The default is the 'src' extension</span></div><div class="L1"><span class="pp-ln"> 111 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> without the ending '.ittf' string, if present.</span></div><div class="L2"><span class="pp-ln"> 112 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> collection</span></div><div class="L3"><span class="pp-ln"> 113 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The name of the data collection to which the front matter properties of the source ittf documents</span></div><div class="L4"><span class="pp-ln"> 114 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> must be appendend. They will be available in the context property 'job.{collection}'</span></div><div class="L5"><span class="pp-ln"> 115 </span><span class="pp-pln">        </span><span class="pp-mix frag-to-link-a">a_flag(</span><span class="pp-arg"> noOutput</span><span class="pp-pln">,</span><span class="pp-arg">  no-output </span><span class="pp-mix">)</span></div><div class="L6"><span class="pp-ln"> 116 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> No artifact should be emitted. Front matter properties are collected.</span></div><div class="L7"><span class="pp-ln"> 117 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> transformer/s</span></div><div class="L8"><span class="pp-ln"> 118 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> When the artifact source is an Ittf document, the loaded WizziModel may need</span></div><div class="L9"><span class="pp-ln"> 119 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> one or more transformations before being passed to the artifact generator.</span></div><div class="L0"><span class="pp-ln"> 120 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Transformers are chained and the output of a transformation</span></div><div class="L1"><span class="pp-ln"> 121 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> is the input for the next one.</span></div><div class="L2"><span class="pp-ln"> 122 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> modelRef/s</span></div><div class="L3"><span class="pp-ln"> 123 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> References to 'model/s' acting as context objects.</span></div><div class="L4"><span class="pp-ln"> 124 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> In case of a final artifact must not be declared.</span></div><div class="L5"><span class="pp-ln"> 125 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> comment/s</span></div>
                                            is-example
                                            rel-dirname C:/My/wizzi/stfnbssl/wizzi/packages/wizzi-mtree/.wizzi/ittf/examples/mixer/ittf__copy/schemas/t/wfjob
                                            rel-uri .wizzi/ittf/examples/mixer/ittf__copy/schemas/t/wfjob/artifact.wfschema.ittf
