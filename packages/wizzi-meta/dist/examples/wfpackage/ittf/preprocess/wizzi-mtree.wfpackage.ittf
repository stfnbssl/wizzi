                                            rel-dirname C:/My/wizzi/stfnbssl/wizzi/packages/wizzi-mtree/.wizzi/ittf/examples/mixer/ittf__copy/schemas/t/wfjob
                                            rel-uri .wizzi/ittf/examples/mixer/ittf__copy/schemas/t/wfjob/model.wfschema.ittf
                                            schema wfschema
                                        d production.wfschema.ittf
                                            id d_61
                                            is-fragment
                                            ittf <div class="L1"><span class="pp-ln">   1 </span><span class="pp-pln"></span><span class="pp-kwd">└group</span></div><div class="L2"><span class="pp-ln">   2 </span><span class="pp-pln">    </span><span class="pp-tag">e</span><span class="pp-pln"> line</span></div><div class="L3"><span class="pp-ln">   3 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> A line is a group of artifacts having the same source "cwdFolder".</span></div><div class="L4"><span class="pp-ln">   4 </span><span class="pp-pln">        </span><span class="pp-mix frag-to-link-a">a_tag(</span><span class="pp-arg"> cwdFolder</span><span class="pp-pln">,</span><span class="pp-arg">  cwd-folder </span><span class="pp-mix">)</span></div><div class="L5"><span class="pp-ln">   5 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The source folder of the artifact templates of this line.</span></div><div class="L6"><span class="pp-ln">   6 </span><span class="pp-pln">        </span><span class="pp-mix frag-to-link-a">a_tag(</span><span class="pp-arg"> destFolder</span><span class="pp-pln">,</span><span class="pp-arg">  dest-folder </span><span class="pp-mix">)</span></div><div class="L7"><span class="pp-ln">   7 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The destination folder of the generated artifacts of this line.</span></div><div class="L8"><span class="pp-ln">   8 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Overrides the attribute "destFolder" of the "production" element.</span></div><div class="L9"><span class="pp-ln">   9 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> artifact/s</span></div><div class="L0"><span class="pp-ln">  10 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The artifacts of the "line"</span></div><div class="L1"><span class="pp-ln">  11 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> comment/s</span></div><div class="L2"><span class="pp-ln">  12 </span><span class="pp-pln">    </span><span class="pp-mix frag-to-link-a">e_tag(</span><span class="pp-arg"> lineRef</span><span class="pp-pln">,</span><span class="pp-arg">  line-ref </span><span class="pp-mix">)</span></div><div class="L3"><span class="pp-ln">  13 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> A reference to a line.</span></div><div class="L4"><span class="pp-ln">  14 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> comment/s</span></div><div class="L5"><span class="pp-ln">  15 </span><span class="pp-pln">    </span><span class="pp-tag">e</span><span class="pp-pln"> production</span></div><div class="L6"><span class="pp-ln">  16 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> A job execution unit that generates a set of Software artifacts</span></div><div class="L7"><span class="pp-ln">  17 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> into one destination folder.</span></div><div class="L8"><span class="pp-ln">  18 </span><span class="pp-pln">        </span><span class="pp-mix frag-to-link-a">a_tag(</span><span class="pp-arg"> destFolder</span><span class="pp-pln">,</span><span class="pp-arg">  dest-folder </span><span class="pp-mix">)</span></div><div class="L9"><span class="pp-ln">  19 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The destination folder of the generated artifacts.</span></div><div class="L0"><span class="pp-ln">  20 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> modelRef/s</span></div><div class="L1"><span class="pp-ln">  21 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> References to the context WizziWodels used by this "production".</span></div><div class="L2"><span class="pp-ln">  22 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> lineRef/s</span></div><div class="L3"><span class="pp-ln">  23 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> References to the "line(s)" to be generated.</span></div><div class="L4"><span class="pp-ln">  24 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> comment/s</span></div><div class="L5"><span class="pp-ln">  25 </span><span class="pp-pln">        </span><span class="pp-tag">m</span><span class="pp-pln"> wzinitialize</span></div><div class="L6"><span class="pp-ln">  26 </span><span class="pp-pln">            </span><span class="pp-tag">set</span><span class="pp-pln"> this.wfjob = this.wzParent;</span></div><div class="L7"><span class="pp-ln">  27 </span><span class="pp-pln">            </span><span class="pp-tag">foreach</span><span class="pp-pln"> modelRef in this.modelRefs</span></div><div class="L8"><span class="pp-ln">  28 </span><span class="pp-pln">                </span><span class="pp-kwd">└└</span><span class="pp-pln"> log 'production.wzinitialize.modelRef', modelRef.wzName</span></div><div class="L9"><span class="pp-ln">  29 </span><span class="pp-pln">                </span><span class="pp-tag">var</span><span class="pp-pln"> model = this.wfjob.getModel(modelRef.wzName)</span></div><div class="L0"><span class="pp-ln">  30 </span><span class="pp-pln">                </span><span class="pp-tag">if</span><span class="pp-pln"> model == null</span></div><div class="L1"><span class="pp-ln">  31 </span><span class="pp-pln">                    </span><span class="pp-tag">_</span><span class="pp-pln"> this.error('Model ' + modelRef.wzName + ' not found.', modelRef)</span></div><div class="L2"><span class="pp-ln">  32 </span><span class="pp-pln">                </span><span class="pp-tag">set</span><span class="pp-pln"> modelRef.___model = model</span></div><div class="L3"><span class="pp-ln">  33 </span><span class="pp-pln">            </span><span class="pp-tag">set</span><span class="pp-pln"> this.lines = [];</span></div><div class="L4"><span class="pp-ln">  34 </span><span class="pp-pln">            </span><span class="pp-tag">foreach</span><span class="pp-pln"> lineRef in this.lineRefs</span></div><div class="L5"><span class="pp-ln">  35 </span><span class="pp-pln">                </span><span class="pp-kwd">└└</span><span class="pp-pln"> log 'production.wzinitialize.lineRef', lineRef.wzName</span></div><div class="L6"><span class="pp-ln">  36 </span><span class="pp-pln">                </span><span class="pp-tag">var</span><span class="pp-pln"> line = this.wfjob.getLine(lineRef.wzName)</span></div><div class="L7"><span class="pp-ln">  37 </span><span class="pp-pln">                </span><span class="pp-tag">if</span><span class="pp-pln"> line == null</span></div><div class="L8"><span class="pp-ln">  38 </span><span class="pp-pln">                    </span><span class="pp-tag">_</span><span class="pp-pln"> this.error('line ' + lineRef.wzName + ' not found.', lineRef)</span></div><div class="L9"><span class="pp-ln">  39 </span><span class="pp-pln">                </span><span class="pp-tag">_</span><span class="pp-pln"> this.lines.push(line)</span></div><div class="L0"><span class="pp-ln">  40 </span><span class="pp-pln">                </span><span class="pp-tag">foreach</span><span class="pp-pln"> artifact in line.artifacts</span></div><div class="L1"><span class="pp-ln">  41 </span><span class="pp-pln">                    </span><span class="pp-kwd">└└</span><span class="pp-pln"> log 'production.wzinitialize.artifact', artifact.wzName</span></div><div class="L2"><span class="pp-ln">  42 </span><span class="pp-pln">                    </span><span class="pp-tag">foreach</span><span class="pp-pln"> modelRef in artifact.modelRefs</span></div><div class="L3"><span class="pp-ln">  43 </span><span class="pp-pln">                        </span><span class="pp-kwd">└└</span><span class="pp-pln"> log 'production.wzinitialize.artifact.modelRef', modelRef.wzName</span></div><div class="L4"><span class="pp-ln">  44 </span><span class="pp-pln">                        </span><span class="pp-tag">var</span><span class="pp-pln"> model = this.wfjob.getModel(modelRef.wzName)</span></div><div class="L5"><span class="pp-ln">  45 </span><span class="pp-pln">                        </span><span class="pp-tag">if</span><span class="pp-pln"> model == null</span></div><div class="L6"><span class="pp-ln">  46 </span><span class="pp-pln">                            </span><span class="pp-tag">_</span><span class="pp-pln"> this.error('Model ' + modelRef.wzName + ' not found.', modelRef)</span></div><div class="L7"><span class="pp-ln">  47 </span><span class="pp-pln">                        </span><span class="pp-tag">set</span><span class="pp-pln"> modelRef.___model = model;</span></div>
