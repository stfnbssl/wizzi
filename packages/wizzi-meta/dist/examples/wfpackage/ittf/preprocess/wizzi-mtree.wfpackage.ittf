">#</span><span class="pp-pln"> The path to the executable.</span></div><div class="L6"><span class="pp-ln">  36 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> title</span></div><div class="L7"><span class="pp-ln">  37 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> A short description of the execution.</span></div><div class="L8"><span class="pp-ln">  38 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> cwd</span></div><div class="L9"><span class="pp-ln">  39 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Current working directory of the child process.</span></div><div class="L0"><span class="pp-ln">  40 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> encoding</span></div><div class="L1"><span class="pp-ln">  41 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Default: 'utf8'</span></div><div class="L2"><span class="pp-ln">  42 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> timeout</span></div><div class="L3"><span class="pp-ln">  43 </span><span class="pp-pln">            </span><span class="pp-tag">type</span><span class="pp-pln"> integer</span></div><div class="L4"><span class="pp-ln">  44 </span><span class="pp-pln">            </span><span class="pp-tag">default</span><span class="pp-pln"> 0</span></div><div class="L5"><span class="pp-ln">  45 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Default: 0</span></div><div class="L6"><span class="pp-ln">  46 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> __options</span></div><div class="L7"><span class="pp-ln">  47 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> __args</span></div><div class="L8"><span class="pp-ln">  48 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> arg/s</span></div><div class="L9"><span class="pp-ln">  49 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> env/s</span></div><div class="L0"><span class="pp-ln">  50 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> comment/s</span></div><div class="L1"><span class="pp-ln">  51 </span><span class="pp-pln">        </span><span class="pp-tag">m</span><span class="pp-pln"> wzinitialize</span></div><div class="L2"><span class="pp-ln">  52 </span><span class="pp-pln">            </span><span class="pp-tag">var</span><span class="pp-pln"> options = {}</span></div><div class="L3"><span class="pp-ln">  53 </span><span class="pp-pln">            </span><span class="pp-tag">if</span><span class="pp-pln"> this.cwd && this.cwd.length &gt; 0</span></div><div class="L4"><span class="pp-ln">  54 </span><span class="pp-pln">                </span><span class="pp-tag">set</span><span class="pp-pln"> options.cwd = this.cwd</span></div><div class="L5"><span class="pp-ln">  55 </span><span class="pp-pln">            </span><span class="pp-tag">if</span><span class="pp-pln"> this.encoding && this.encoding.length &gt; 0</span></div><div class="L6"><span class="pp-ln">  56 </span><span class="pp-pln">                </span><span class="pp-tag">set</span><span class="pp-pln"> options.encoding = this.encoding</span></div><div class="L7"><span class="pp-ln">  57 </span><span class="pp-pln">            </span><span class="pp-tag">if</span><span class="pp-pln"> this.timeout &gt; 0</span></div><div class="L8"><span class="pp-ln">  58 </span><span class="pp-pln">                </span><span class="pp-tag">set</span><span class="pp-pln"> options.timeout = this.timeout</span></div><div class="L9"><span class="pp-ln">  59 </span><span class="pp-pln">            </span><span class="pp-tag">if</span><span class="pp-pln"> this.envs.length &gt; 0</span></div><div class="L0"><span class="pp-ln">  60 </span><span class="pp-pln">                </span><span class="pp-tag">var</span><span class="pp-pln"> envObj = {}</span></div><div class="L1"><span class="pp-ln">  61 </span><span class="pp-pln">                </span><span class="pp-tag">foreach</span><span class="pp-pln"> env in this.envs</span></div><div class="L2"><span class="pp-ln">  62 </span><span class="pp-pln">                    </span><span class="pp-tag">set</span><span class="pp-pln"> envObj[env.__name] = env.__value</span></div><div class="L3"><span class="pp-ln">  63 </span><span class="pp-pln">                </span><span class="pp-tag">set</span><span class="pp-pln"> options.env = envObj</span></div><div class="L4"><span class="pp-ln">  64 </span><span class="pp-pln">            </span><span class="pp-tag">set</span><span class="pp-pln"> this.__options = options</span></div><div class="L5"><span class="pp-ln">  65 </span><span class="pp-pln">            </span><span class="pp-tag">set</span><span class="pp-pln"> this.__args = []</span></div><div class="L6"><span class="pp-ln">  66 </span><span class="pp-pln">            </span><span class="pp-tag">foreach</span><span class="pp-pln"> arg in this.args</span></div><div class="L7"><span class="pp-ln">  67 </span><span class="pp-pln">                </span><span class="pp-tag">_</span><span class="pp-pln"> this.__args.push(arg.__value)</span></div>
                                            is-example
                                            rel-dirname C:/My/wizzi/stfnbssl/wizzi/packages/wizzi-mtree/.wizzi/ittf/examples/mixer/ittf__copy/schemas/t/wfjob
                                            rel-uri .wizzi/ittf/examples/mixer/ittf__copy/schemas/t/wfjob/exec.wfschema.ittf
                                            schema wfschema
                                        d model.wfschema.ittf
                                            id d_60
                                            is-fragment
                                            ittf <div class="L1"><span class="pp-ln">   1 </span><span class="pp-pln"></span><span class="pp-kwd">└group</span></div><div class="L2"><span class="pp-ln">   2 </span><span class="pp-pln">    </span><span class="pp-tag">e</span><span class="pp-pln"> model</span></div><div class="L3"><span class="pp-ln">   3 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> A wizzi model instance or a POJO acting as a context during an mTree loading.</span></div><div class="L4"><span class="pp-ln">   4 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> The ittf node value (wzName) is the name of the model that must be unique</span></div><div class="L5"><span class="pp-ln">   5 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> in a "wfjob"; it will become the default export name of the context</span></div><div class="L6"><span class="pp-ln">   6 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> property that exposes the model.</span></div><div class="L7"><span class="pp-ln">   7 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> A "model" will be loaded once, and will be reused if</span></div><div class="L8"><span class="pp-ln">   8 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> referenced in many evaluations.</span></div><div class="L9"><span class="pp-ln">   9 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> src</span></div><div class="L0"><span class="pp-ln">  10 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The path to the primary ittf document of the "model" or to the the POJO source.</span></div><div class="L1"><span class="pp-ln">  11 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> When relative, the base path is the "modelsBaseFolder"</span></div><div class="L2"><span class="pp-ln">  12 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> declared on the "wfjob" element.</span></div><div class="L3"><span class="pp-ln">  13 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> schema</span></div><div class="L4"><span class="pp-ln">  14 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> In case of a wizzi model is the name of its wizzi schema.</span></div><div class="L5"><span class="pp-ln">  15 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Is alternative to the attribute 'format'.</span></div><div class="L6"><span class="pp-ln">  16 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> format</span></div><div class="L7"><span class="pp-ln">  17 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> In case of a POJO model is the native format of the source file.</span></div><div class="L8"><span class="pp-ln">  18 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Is alternative to the attribute 'schema'.</span></div><div class="L9"><span class="pp-ln">  19 </span><span class="pp-pln">            </span><span class="pp-tag">restrict</span></div><div class="L0"><span class="pp-ln">  20 </span><span class="pp-pln">                </span><span class="pp-tag">enum</span><span class="pp-pln"> json</span></div><div class="L1"><span class="pp-ln">  21 </span><span class="pp-pln">                    </span><span class="pp-tag">#</span><span class="pp-pln"> Native JSON file.</span></div><div class="L2"><span class="pp-ln">  22 </span><span class="pp-pln">                </span><span class="pp-tag">enum</span><span class="pp-pln"> xml</span></div><div class="L3"><span class="pp-ln">  23 </span><span class="pp-pln">                    </span><span class="pp-tag">#</span><span class="pp-pln"> Native Xml file.</span></div><div class="L4"><span class="pp-ln">  24 </span><span class="pp-pln">                </span><span class="pp-tag">enum</span><span class="pp-pln"> js</span></div><div class="L5"><span class="pp-ln">  25 </span><span class="pp-pln">                    </span><span class="pp-tag">#</span><span class="pp-pln"> Native javascript module file that may export object properties or</span></div><div class="L6"><span class="pp-ln">  26 </span><span class="pp-pln">                    </span><span class="pp-tag">#</span><span class="pp-pln"> a function named 'toModel'.</span></div><div class="L7"><span class="pp-ln">  27 </span><span class="pp-pln">        </span><span class="pp-mix frag-to-link-a">a_tag(</span><span class="pp-arg"> dumpFile</span><span class="pp-pln">,</span><span class="pp-arg">  dump-file </span><span class="pp-mix">)</span></div><div class="L8"><span class="pp-ln">  28 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> A filepath where the loaded model must be dumped for test.</span></div><div class="L9"><span class="pp-ln">  29 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The model must implement the toJson method. See the "exportTo" attribute in wizzischema root nodes.</span></div><div class="L0"><span class="pp-ln">  30 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> When declared the loaded model is JSON.stringyfied and written</span></div><div class="L1"><span class="pp-ln">  31 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> to the "dumpFile" filepath.</span></div><div class="L2"><span class="pp-ln">  32 </span><span class="pp-pln">        </span><span class="pp-mix frag-to-link-a">a_tag(</span><span class="pp-arg"> exportName</span><span class="pp-pln">,</span><span class="pp-arg">  export-name </span><span class="pp-mix">)</span></div><div class="L3"><span class="pp-ln">  33 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The name of the context property that will expose the loaded model.</span></div><div class="L4"><span class="pp-ln">  34 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> When declared on the "model" element means that the model will be globally available</span></div><div class="L5"><span class="pp-ln">  35 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> for all the transformations of the job.</span></div><div class="L6"><span class="pp-ln">  36 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> modelRef/s</span></div><div class="L7"><span class="pp-ln">  37 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> References to "model" instances acting as data context during this "model" evaluation.</span></div><div class="L8"><span class="pp-ln">  38 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> A "model" is referenced by its name.</span></div><div class="L9"><span class="pp-ln">  39 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> comment/s</span></div><div class="L0"><span class="pp-ln">  40 </span><span class="pp-pln">    </span><span class="pp-mix frag-to-link-a">e_tag(</span><span class="pp-arg"> modelRef</span><span class="pp-pln">,</span><span class="pp-arg">  model-ref </span><span class="pp-mix">)</span></div><div class="L1"><span class="pp-ln">  41 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> Can be a child element of a "model" element, an "artifact" element and a "transformer" element.</span></div><div class="L2"><span class="pp-ln">  42 </span><span class="pp-pln">        </span><span class="pp-mix frag-to-link-a">a_tag(</span><span class="pp-arg"> exportName</span><span class="pp-pln">,</span><span class="pp-arg">  export-name </span><span class="pp-mix">)</span></div><div class="L3"><span class="pp-ln">  43 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The name of the context property that will expose the loaded model during</span></div><div class="L4"><span class="pp-ln">  44 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> an evaluation. Overrides the name of the "model" that is the default export name.</span></div><div class="L5"><span class="pp-ln">  45 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> transformer/s</span></div><div class="L6"><span class="pp-ln">  46 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> A model may have one or more transformers.</span></div><div class="L7"><span class="pp-ln">  47 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Transformers are chained and the output of a transformation</span></div><div class="L8"><span class="pp-ln">  48 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> is the input for the next one.</span></div><div class="L9"><span class="pp-ln">  49 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> modelCollection/s</span></div><div class="L0"><span class="pp-ln">  50 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> TODO This is a one-to-one relation, not yet implemented.</span></div><div class="L1"><span class="pp-ln">  51 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Single items of a collection contained in the "model" may act as a context property</span></div><div class="L2"><span class="pp-ln">  52 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> for artifacts where each collection item generates a separate artifact.</span></div><div class="L3"><span class="pp-ln">  53 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> comment/s</span></div><div class="L4"><span class="pp-ln">  54 </span><span class="pp-pln">        </span><span class="pp-tag">m</span><span class="pp-pln"> wzinitialize</span></div><div class="L5"><span class="pp-ln">  55 </span><span class="pp-pln">            </span><span class="pp-tag">if</span><span class="pp-pln"> this.modelCollections.length &gt; 0</span></div><div class="L6"><span class="pp-ln">  56 </span><span class="pp-pln">                </span><span class="pp-tag">set</span><span class="pp-pln"> this.modelCollection = this.modelCollections[0]</span></div><div class="L7"><span class="pp-ln">  57 </span><span class="pp-pln">                </span><span class="pp-tag">set</span><span class="pp-pln"> this.collName = this.modelCollection.wzName</span></div><div class="L8"><span class="pp-ln">  58 </span><span class="pp-pln">                </span><span class="pp-tag">set</span><span class="pp-pln"> this.collItemName = this.modelCollection.itemName</span></div><div class="L9"><span class="pp-ln">  59 </span><span class="pp-pln">                </span><span class="pp-tag">set</span><span class="pp-pln"> this.collPathTemplateValues = []</span></div><div class="L0"><span class="pp-ln">  60 </span><span class="pp-pln">                </span><span class="pp-tag">foreach</span><span class="pp-pln"> item in this.modelCollection.pathTemplateValues</span></div><div class="L1"><span class="pp-ln">  61 </span><span class="pp-pln">                    </span><span class="pp-tag">_</span><span class="pp-pln"> this.collPathTemplateValues.push</span></div><div class="L2"><span class="pp-ln">  62 </span><span class="pp-pln">                        </span><span class="pp-tag">{</span></div><div class="L3"><span class="pp-ln">  63 </span><span class="pp-pln">                            </span><span class="pp-tag">@</span><span class="pp-pln"> token item.token</span></div><div class="L4"><span class="pp-ln">  64 </span><span class="pp-pln">                            </span><span class="pp-tag">@</span><span class="pp-pln"> attribute item.attribute</span></div><div class="L5"><span class="pp-ln">  65 </span><span class="pp-pln">                            </span><span class="pp-tag">@</span><span class="pp-pln"> function item.function</span></div><div class="L6"><span class="pp-ln">  66 </span><span class="pp-pln">                </span><span class="pp-kwd">└└</span><span class="pp-pln"> log 'this.modelCollection.wzName', this.modelCollection.wzName</span></div><div class="L7"><span class="pp-ln">  67 </span><span class="pp-pln">                </span><span class="pp-kwd">└└</span><span class="pp-pln"> log 'this.collName', this.collName</span></div><div class="L8"><span class="pp-ln">  68 </span><span class="pp-pln">                </span><span class="pp-kwd">└└</span><span class="pp-pln"> log 'this.collItemName', this.collItemName</span></div><div class="L9"><span class="pp-ln">  69 </span><span class="pp-pln">    </span><span class="pp-mix frag-to-link-a">e_tag(</span><span class="pp-arg"> modelCollection</span><span class="pp-pln">,</span><span class="pp-arg">  model-coll </span><span class="pp-mix">)</span></div><div class="L0"><span class="pp-ln">  70 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> Single items of a collection contained in a "model" may act as data contexts</span></div><div class="L1"><span class="pp-ln">  71 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> of artifacts where each collection item generates a separate artifact.</span></div><div class="L2"><span class="pp-ln">  72 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> This element, contained in a "modelRef" element, specifies:</span></div><div class="L3"><span class="pp-ln">  73 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> . the collection name: the IttfNodeValue of this element</span></div><div class="L4"><span class="pp-ln">  74 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> . the export name of the collection item when acting as a context property: the "item-name" attribute</span></div><div class="L5"><span class="pp-ln">  75 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> . the property names of the collection item that will be used to build the destination path</span></div><div class="L6"><span class="pp-ln">  76 </span><span class="pp-pln">        </span><span class="pp-tag">#</span><span class="pp-pln"> of the artifact: the "pathTemplateValues" child elements</span></div><div class="L7"><span class="pp-ln">  77 </span><span class="pp-pln">        </span><span class="pp-mix frag-to-link-a">a_tag(</span><span class="pp-arg"> itemName</span><span class="pp-pln">,</span><span class="pp-arg">  item-name </span><span class="pp-mix">)</span></div><div class="L8"><span class="pp-ln">  78 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The export name of a collection item when acting as a context property.</span></div><div class="L9"><span class="pp-ln">  79 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> pathTemplateValue/s</span></div><div class="L0"><span class="pp-ln">  80 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> comment/s</span></div><div class="L1"><span class="pp-ln">  81 </span><span class="pp-pln">    </span><span class="pp-mix frag-to-link-a">e_tag(</span><span class="pp-arg"> pathTemplateValue</span><span class="pp-pln">,</span><span class="pp-arg">  path-template-value </span><span class="pp-mix">)</span></div><div class="L2"><span class="pp-ln">  82 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> attribute</span></div><div class="L3"><span class="pp-ln">  83 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The property of the context object (a collection item) containing the value which will replace</span></div><div class="L4"><span class="pp-ln">  84 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> the "token" value in the generated artifact path template.</span></div><div class="L5"><span class="pp-ln">  85 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Is alternative to "function"</span></div><div class="L6"><span class="pp-ln">  86 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> function</span></div><div class="L7"><span class="pp-ln">  87 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The function of the context object (a collection item) that returns the value which will replace</span></div><div class="L8"><span class="pp-ln">  88 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> the "token" value in the generated artifact path template.</span></div><div class="L9"><span class="pp-ln">  89 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> Is alternative to "attribute"</span></div><div class="L0"><span class="pp-ln">  90 </span><span class="pp-pln">        </span><span class="pp-tag">a</span><span class="pp-pln"> token</span></div><div class="L1"><span class="pp-ln">  91 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> The token that will be replaced by the value returned accessing "attribute" or calling "function"</span></div><div class="L2"><span class="pp-ln">  92 </span><span class="pp-pln">            </span><span class="pp-tag">#</span><span class="pp-pln"> on a context object.</span></div><div class="L3"><span class="pp-ln">  93 </span><span class="pp-pln">        </span><span class="pp-tag">r</span><span class="pp-pln"> comment/s</span></div>
