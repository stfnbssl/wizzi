module 
    kind jsfile
	+
	import path
	import util
    var file = require('wizzi-utils').file;
	+
    var expect = require('expect.js')
	var thisPackage = require('../../index')
	+
	var simpleSource
        _ file.read
            _ path.join
                @ __dirname
                @ 'data'
                @ 'simple.tests.html'
	+
	describe the html wizzifier
		+ 
		it-async should wizzify an html file

			var ittfExpected = 'html \n    head\n    body\n        div alfa\n'
			
			_ thisPackage.htmlwizzifier.getWizziIttf
				@ simpleSource
				{
				f_cb_test( ittf )
					tobe_string_value.js( ittf, ittfExpected )
					_ done()
