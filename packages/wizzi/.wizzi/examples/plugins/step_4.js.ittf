module
	kind es6

    $
        var opt = {
            level: 0,
            step: 1,
            name: 'mm_step_4',
            title: 'Meta plugin - get provides',
            folderLevel: 2
        }

    common\example\wizzi( &opt )

        $append plugins
            [ items
                @ './wizzi.plugin.ittf/index'
                @ './wizzi.plugin.css/index'
            @ pluginsBaseFolder pluginsBaseFolderV08
        +
        _ createWizziFactory
            {
            f_cb_test(wf)
                var hasCS = wf.hasCheatsheet('ittf')
                log 'Wizzi factory has cheatsheet for schema `ittf`', hasCS
                log 'Wizzi factory info\n', JSON.stringify(wf.getInfo().pluginsManager, null, 4)
                if hasCS
                    _ wf.getCheatsheet
                        @ 'ittf'
                        f_cb_test(CS)
                            log 'err', err
                            log 'cheatsheet', CS
